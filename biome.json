{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": {
		"includes": ["**", "!bun.lock", "!test/__snapshots__", "!test/fixtures", "!node_modules"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded",
			"trailingCommas": "all",
			"arrowParentheses": "always"
		}
	},
	"linter": {
		"enabled": true,
		"rules": { "recommended": true }
	}
}
